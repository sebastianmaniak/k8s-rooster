server {
    listen 80;
    server_name _;

    access_log /var/log/nginx/compliance-portal.access.log;
    error_log  /var/log/nginx/compliance-portal.error.log;

    # Frontend
    location / {
        root /var/www/compliance-portal;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # Backend API
    location /api/ {
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Use inventory-driven backend target to avoid stale/incorrect IPs causing 502.
        proxy_pass http://{{ compliance_backend_host }}:{{ compliance_backend_port }}/;
    }
}
