# Managed by Ansible
# compliance portal nginx site

upstream compliance_backend {
    # Inventory-driven backend selection.
    # Defaults:
    #   host: first host in group 'appservers' (ansible_host if set, else inventory_hostname)
    #   port: 8000
    server {{ compliance_backend_host | default(hostvars[groups['appservers'][0]].ansible_host | default(groups['appservers'][0])) }}:{{ compliance_backend_port | default(8000) }};
}

server {
    listen 80;
    server_name _;

    # health check endpoint
    location /health {
        access_log off;
        return 200 "ok\n";
        add_header Content-Type text/plain;
    }

    location / {
        proxy_pass http://compliance_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
